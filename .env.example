# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Neo4j (optional — only needed for knowledge graph persistence)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Simulation
SIM_MAX_TURNS=20
SIM_PLATFORM=discussion
